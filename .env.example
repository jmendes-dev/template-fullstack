# .env.example — Copiar para .env e preencher os valores
# ⚠️  NUNCA commitar o .env — apenas o .env.example vai no git
# UAT/PRD: variáveis configuradas na UI do Portainer ou Railway (nunca no compose)

# ── Banco de dados ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp_dev
# Porta do PostgreSQL (usado no docker-compose.yml)
PGPORT=5432

# ── Autenticação (Clerk) ───────────────────────────────────────
# Obter em: https://dashboard.clerk.com → API Keys
# Deixar em branco para rodar sem auth em dev (retorna userId: "dev-user")
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# ── API ────────────────────────────────────────────────────────
PORT=3000
# Origins permitidas para CORS (separadas por vírgula)
APP_CORS_ORIGINS=http://localhost:4000

# ── Frontend ───────────────────────────────────────────────────
WEB_PORT=4000
# URL da API para o frontend (dev: http://localhost:3000 | prod nginx: "" vazio = same-origin)
VITE_API_URL=http://localhost:3000

# ── Storage S3-compatible ──────────────────────────────────────
# Dev: aponta para o MinIO local (container no docker-compose)
# UAT/PRD: aponta para MinIO central via Portainer UI
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=uploads
# "true" obrigatório para S3-compatible (MinIO, Cloudflare R2, etc.)
S3_FORCE_PATH_STYLE=true

# ── MinIO local (apenas dev) ───────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Backup PostgreSQL → MinIO ──────────────────────────────────
# Container sidecar backup-postgres roda pg_dump → MinIO em loop
S3_BACKUP_BUCKET=backup-myapp-db
BACKUP_RETENTION_DAYS=7
# Intervalo entre backups em segundos (86400 = 24h)
BACKUP_INTERVAL=86400

# ── Deploy on-premises (Portainer) ────────────────────────────
# Registry Docker privado (ex: 10.10.254.66:5000)
REGISTRY=10.10.254.66:5000
# Prefixo das imagens: APP_NAME-api, APP_NAME-web
APP_NAME=myapp
