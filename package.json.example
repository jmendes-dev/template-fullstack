{
  "name": "@projeto/root",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter=* dev",
    "dev:api": "bun run --filter=@projeto/api dev",
    "dev:web": "bun run --filter=@projeto/web dev",
    "build": "bun run --filter=* build",
    "test": "bun test",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^5.8.0"
  },
  "_comment_workspaces": {
    "apps/api/package.json": {
      "name": "@projeto/api",
      "dependencies": {
        "@projeto/shared": "workspace:*",
        "hono": "^4.12.4",
        "@hono/standard-validator": "latest",
        "drizzle-orm": "^0.41.0",
        "postgres": "^3.4.0",
        "zod": "^4.0.0",
        "@clerk/backend": "latest"
      },
      "devDependencies": {
        "drizzle-kit": "^0.31.0"
      }
    },
    "apps/web/package.json": {
      "name": "@projeto/web",
      "dependencies": {
        "@projeto/shared": "workspace:*",
        "@projeto/api": "workspace:*",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router": "^7.0.0",
        "@tanstack/react-query": "^5.0.0",
        "zustand": "^5.0.0",
        "react-hook-form": "^7.0.0",
        "@hookform/resolvers": "^3.0.0",
        "zod": "^4.0.0",
        "sonner": "^2.0.0",
        "@clerk/react": "latest"
      },
      "devDependencies": {
        "vite": "^8.0.0",
        "@tailwindcss/vite": "^4.0.0"
      }
    },
    "packages/shared/package.json": {
      "name": "@projeto/shared",
      "exports": {
        ".": "./src/index.ts"
      },
      "dependencies": {
        "drizzle-orm": "^0.41.0",
        "drizzle-zod": "^0.7.0",
        "zod": "^4.0.0"
      }
    }
  }
}
